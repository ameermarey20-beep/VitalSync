<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="25dp">

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome, User!"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#22262A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tvWelcome"
                android:text="VitalSync Dashboard"
                android:textSize="14sp"
                android:textColor="#7A8086"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvConnectionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerInParent="true"
                android:background="@android:drawable/toast_frame"
                android:backgroundTint="#FF9800"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="Waiting for Robot..."
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="#FFFFFF"
            android:orientation="vertical"
            android:padding="24dp"
            android:elevation="4dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HEART RATE MONITOR"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#9E9E9E"
                android:letterSpacing="0.1"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="15dp">

                <TextView
                    android:id="@+id/tvHeartRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="72sp"
                    android:textStyle="bold"
                    android:textColor="#E53935" />

                <TextView
                    android:id="@+id/tvBpmUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/tvHeartRate"
                    android:layout_alignBottom="@id/tvHeartRate"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="16dp"
                    android:text="BPM"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#E53935" />
            </RelativeLayout>

            <ProgressBar
                android:id="@+id/pulseProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progress="0"
                android:max="200"
                android:progressTint="#E53935"
                android:layout_marginBottom="10dp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnConnectBluetooth"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Connect Bluetooth"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#006492"
            android:elevation="4dp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="#FFFFFF"
            android:orientation="horizontal"
            android:padding="18dp"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current Condition"
                    android:textSize="14sp"
                    android:textColor="#7A8086" />

                <TextView
                    android:id="@+id/tvCondition"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No Data"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#3F4850"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <View
                android:id="@+id/viewStatusIndicator"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:background="@android:drawable/presence_invisible"
                android:backgroundTint="#9E9E9E"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:drawable/dialog_holo_light_frame"
                android:backgroundTint="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp"
                android:elevation="4dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Blood Oxygen"
                    android:textSize="12sp"
                    android:textColor="#7A8086" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="98 %"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#006492"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:drawable/dialog_holo_light_frame"
                android:backgroundTint="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp"
                android:elevation="4dp"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Robot Battery"
                    android:textSize="12sp"
                    android:textColor="#7A8086" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="85 %"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#1FA95C"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:backgroundTint="#EEEEEE"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤖 Arduino Nano Connected • Bluetooth 5.0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#3F4850" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>