<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="28dp">

            <TextView
                android:id="@+id/tvStatsHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Health Trends"
                android:textSize="28sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/primaryNavy" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tvStatsHeader"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_status_chip"
                android:backgroundTint="@color/normalBg"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:text="Weekly Status: Stable"
                android:textColor="@color/normalText"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"/>
        </RelativeLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="300dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="10dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@color/cardBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24H HEART RATE TREND"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/textSecondary"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="16dp"/>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/statsTrendChart"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical"
                    android:background="@color/cardBackground">

                    <View
                        android:layout_width="6dp"
                        android:layout_height="40dp"
                        android:background="@color/highText"
                        android:layout_marginEnd="16dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Highest Peak"
                            android:textSize="13sp"
                            android:textColor="@color/textSecondary" />
                        <TextView
                            android:id="@+id/tvStatHighest"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="112 BPM"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/primaryNavy"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="@color/highText"
                        android:alpha="0.8"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical"
                    android:background="@color/cardBackground">

                    <View
                        android:layout_width="6dp"
                        android:layout_height="40dp"
                        android:background="@color/accentElectric"
                        android:layout_marginEnd="16dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lowest Point"
                            android:textSize="13sp"
                            android:textColor="@color/textSecondary" />
                        <TextView
                            android:id="@+id/tvStatLowest"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="64 BPM"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/primaryNavy"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_menu_revert"
                        app:tint="@color/accentElectric"
                        android:alpha="0.8"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical"
                    android:background="@color/cardBackground">

                    <View
                        android:layout_width="6dp"
                        android:layout_height="40dp"
                        android:background="@color/normalText"
                        android:layout_marginEnd="16dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Daily Average"
                            android:textSize="13sp"
                            android:textColor="@color/textSecondary" />
                        <TextView
                            android:id="@+id/tvStatAverage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="78 BPM"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/primaryNavy"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_menu_info_details"
                        app:tint="@color/normalText"
                        android:alpha="0.8"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
